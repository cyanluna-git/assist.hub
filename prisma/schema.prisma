// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Course {
  id          String       @id // 구글 클래스룸 ID (예: 841669156744)
  title       String
  materials   Material[]
  assignments Assignment[]
}

model Material {
  id          String   @id // Use relative URL as ID
  courseId    String
  title       String
  type        String   // "pdf" | "md" | "zip"
  localUrl    String   // "/materials/announcements/..."
  isRead      Boolean  @default(false)
  notes       Note[]
  course      Course   @relation(fields: [courseId], references: [id])
}

model Note {
  id          String   @id @default(uuid())
  materialId  String
  content     String   // 마크다운 형식의 텍스트
  aiSummary   String?  // AI가 생성한 요약본
  updatedAt   DateTime @updatedAt
  material    Material @relation(fields: [materialId], references: [id])
}

model Assignment {
  id          String    @id
  courseId    String
  title       String
  dueDate     DateTime?
  status      String    // "TODO" | "IN_PROGRESS" | "DONE"
  submittedAt DateTime?
  course      Course    @relation(fields: [courseId], references: [id])
}

model ManualScheduleItem {
  id          String   @id @default(uuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  isPinned    Boolean  @default(false)
  status      String   @default("TODO")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BulletinItem {
  id         String   @id @default(uuid())
  sourceType String   // "SMS" | "GMAIL"
  externalId String?  @unique
  title      String
  content    String
  sender     String?
  isRead     Boolean  @default(false)
  isPinned   Boolean  @default(false)
  isArchived Boolean  @default(false)
  receivedAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SyncState {
  key             String   @id
  label           String
  status          String   @default("IDLE")
  lastStartedAt   DateTime?
  lastFinishedAt  DateTime?
  lastSucceededAt DateTime?
  lastMessage     String?
  lastItemCount   Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CalendarExportRecord {
  id         String   @id @default(uuid())
  calendarId String
  sourceType String
  sourceId   String
  eventId    String
  exportedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([calendarId, sourceType, sourceId])
}

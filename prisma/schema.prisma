// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Course {
  id          String       @id // 구글 클래스룸 ID (예: 841669156744)
  title       String
  materials   Material[]
  assignments Assignment[]
}

model WorkspaceProfile {
  id          String   @id
  displayName String
  studentId   String?
  avatarLabel String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Material {
  id          String   @id // Use relative URL as ID
  courseId    String
  title       String
  type        String   // "pdf" | "md" | "zip"
  localUrl    String   // "/materials/announcements/..."
  isRead      Boolean  @default(false)
  notes       Note[]
  artifacts   MaterialArtifact[]
  course      Course   @relation(fields: [courseId], references: [id])
}

model Note {
  id          String   @id @default(uuid())
  materialId  String
  content     String   // 마크다운 형식의 텍스트
  aiSummary   String?  // 문서별 수동 요약 입력용 Markdown 텍스트
  updatedAt   DateTime @updatedAt
  material    Material @relation(fields: [materialId], references: [id])
}

model MaterialArtifact {
  id               String   @id @default(uuid())
  materialId       String
  artifactType     String   // legacy "NOTEBOOKLM_SUMMARY" | "SLIDES" | "INFOGRAPHIC" | "AUDIO_OVERVIEW" | "MINDMAP"
  status           String   @default("PENDING") // "PENDING" | "RUNNING" | "SUCCESS" | "ERROR"
  sourceNotebookId String?  // NotebookLM notebook/studio identifier
  sourceArtifactId String?  // NotebookLM artifact identifier
  localPath        String?  // Local filesystem path if the artifact is downloaded
  publicUrl        String?  // App-served URL or external URL for opening the artifact
  errorMessage     String?  // Last generation/download error for retry UX
  generatedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  material         Material @relation(fields: [materialId], references: [id])

  @@unique([materialId, artifactType])
}

model Assignment {
  id          String    @id
  courseId    String
  title       String
  dueDate     DateTime?
  status      String    // "TODO" | "IN_PROGRESS" | "DONE"
  submittedAt DateTime?
  course      Course    @relation(fields: [courseId], references: [id])
}

model ManualScheduleItem {
  id          String   @id @default(uuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  isPinned    Boolean  @default(false)
  status      String   @default("TODO")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BulletinItem {
  id         String   @id @default(uuid())
  sourceType String   // "SMS" | "GMAIL"
  externalId String?  @unique
  title      String
  content    String
  sender     String?
  isRead     Boolean  @default(false)
  isPinned   Boolean  @default(false)
  isArchived Boolean  @default(false)
  attachmentsSyncedAt DateTime?
  receivedAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  attachments BulletinAttachment[]
}

model BulletinAttachment {
  id                String       @id @default(uuid())
  bulletinId        String
  gmailAttachmentId String
  filename          String
  mimeType          String?
  localPath         String
  publicUrl         String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  bulletin          BulletinItem @relation(fields: [bulletinId], references: [id], onDelete: Cascade)

  @@unique([bulletinId, gmailAttachmentId])
}

model ExternalFeedSource {
  id            String             @id
  label         String
  feedUrl       String
  siteUrl       String?
  sourceType    String             @default("RSS")
  isActive      Boolean            @default(true)
  lastFetchedAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  items         ExternalFeedItem[]
}

model ExternalFeedItem {
  id          String             @id @default(uuid())
  sourceId    String
  externalKey String
  title       String
  url         String
  summary     String?
  author      String?
  isRead      Boolean            @default(false)
  isArchived  Boolean            @default(false)
  publishedAt DateTime?
  fetchedAt   DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  source      ExternalFeedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalKey])
}

model SyncState {
  key             String   @id
  label           String
  status          String   @default("IDLE")
  lastStartedAt   DateTime?
  lastFinishedAt  DateTime?
  lastSucceededAt DateTime?
  lastMessage     String?
  lastItemCount   Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CalendarExportRecord {
  id         String   @id @default(uuid())
  calendarId String
  sourceType String
  sourceId   String
  eventId    String
  exportedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([calendarId, sourceType, sourceId])
}

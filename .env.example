DATABASE_URL="file:./assist.db"

# Optional: use external backing folders while keeping the same public URLs.
# Each public/* mount should point at the same real path, typically via symlink.
# Example:
# MATERIALS_STORAGE_ROOT="$HOME/Library/CloudStorage/GoogleDrive-your-account/My Drive/dev_blob/assist_hub_classroom_materials"
# ARTIFACT_STORAGE_ROOT="$HOME/Library/CloudStorage/GoogleDrive-your-account/My Drive/dev_blob/assist_hub_artifacts"
# GMAIL_ATTACHMENT_STORAGE_ROOT="$HOME/Library/CloudStorage/GoogleDrive-your-account/My Drive/dev_blob/assist_hub_gmail_attachments"
MATERIALS_STORAGE_ROOT=""
ARTIFACT_STORAGE_ROOT=""
GMAIL_ATTACHMENT_STORAGE_ROOT=""
